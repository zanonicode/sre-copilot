{
  "title": "LLM Performance",
  "uid": "llm-perf",
  "schemaVersion": 36,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "TTFT p95 (10m)",
      "description": "95th percentile time-to-first-token. The canary AnalysisTemplate fails the rollout above 2s.",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "noValue": "—",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1.5 }, { "color": "red", "value": 2.0 }]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "value" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(llm_ttft_seconds_bucket[10m])))",
          "legendFormat": "p95 TTFT",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Full Response p90 (10m)",
      "description": "End-to-end LLM stream completion time at p90.",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1,
          "noValue": "—",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 20.0 }, { "color": "red", "value": 30.0 }]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "value" },
      "targets": [
        {
          "expr": "histogram_quantile(0.90, sum by (le) (rate(llm_response_seconds_bucket[10m])))",
          "legendFormat": "p90 full-response",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Output Tokens/s",
      "description": "Stream throughput across all in-flight LLM calls.",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "noValue": "0",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "value" },
      "targets": [
        {
          "expr": "sum(rate(llm_tokens_output_total[1m])) or vector(0)",
          "legendFormat": "tokens/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active LLM Requests",
      "description": "Currently in-flight Ollama calls (LLM_ACTIVE up-down counter).",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 4 }, { "color": "red", "value": 8 }]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "value" },
      "targets": [
        {
          "expr": "sum(llm_active_requests) or vector(0)",
          "legendFormat": "active",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "TTFT Distribution Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(llm_ttft_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(llm_ttft_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(llm_ttft_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Token Throughput",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "rate(llm_tokens_output_total[5m])",
          "legendFormat": "output tokens/s",
          "refId": "A"
        },
        {
          "expr": "rate(llm_tokens_input_total[5m])",
          "legendFormat": "input tokens/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Recent LLM Traces (via Loki, click traceid to open in Tempo)",
      "description": "Backend log lines for /analyze/* and /generate/* endpoints with trace context. Each traceid value is a clickable link to Tempo via Loki's derivedFields. Loki + Tempo correlation without needing TraceQL backend search.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "datasource": { "uid": "loki" },
      "options": { "showTime": true, "sortOrder": "Descending", "dedupStrategy": "none", "wrapLogMessage": true, "prettifyLogMessage": false, "enableLogDetails": true, "showLabels": false, "showCommonLabels": false },
      "targets": [
        {
          "expr": "{service_name=\"sre-copilot-backend\"} |~ \"/analyze/|/generate/\"",
          "refId": "A"
        }
      ]
    }
  ]
}
