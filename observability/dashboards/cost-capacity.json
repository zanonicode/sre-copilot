{
  "title": "Cost and Capacity",
  "uid": "cost-capacity",
  "schemaVersion": 36,
  "refresh": "60s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Cluster Memory Requested",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(kube_pod_container_resource_requests{resource=\"memory\", namespace=~\"sre-copilot|platform|observability\"})",
          "legendFormat": "memory requested",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Cluster CPU Requested",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(kube_pod_container_resource_requests{resource=\"cpu\", namespace=~\"sre-copilot|platform|observability\"})",
          "legendFormat": "CPU cores requested",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Input Tokens (session)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["sum"] } },
      "targets": [
        {
          "expr": "increase(llm_tokens_input_total[6h])",
          "legendFormat": "input tokens",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Output Tokens (session)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["sum"] } },
      "targets": [
        {
          "expr": "increase(llm_tokens_output_total[6h])",
          "legendFormat": "output tokens",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Memory Utilization by Namespace",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "sum by (namespace) (container_memory_working_set_bytes{namespace=~\"sre-copilot|platform|observability\", container!=\"\"})",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "CPU Utilization by Namespace",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "sum by (namespace) (rate(container_cpu_usage_seconds_total{namespace=~\"sre-copilot|platform|observability\", container!=\"\"}[5m]))",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Token Cost Proxy (tokens per request)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "rate(llm_tokens_output_total[5m]) / rate(http_server_duration_milliseconds_count{service_name=\"sre-copilot-backend\"}[5m])",
          "legendFormat": "output tokens/req",
          "refId": "A"
        },
        {
          "expr": "rate(llm_tokens_input_total[5m]) / rate(http_server_duration_milliseconds_count{service_name=\"sre-copilot-backend\"}[5m])",
          "legendFormat": "input tokens/req",
          "refId": "B"
        }
      ]
    }
  ]
}
